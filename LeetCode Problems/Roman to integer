var romanToInt = function(s) 
{
    const sym = { 'I': 1, 'V': 5, 'X': 10, 'L': 50, 'C': 100, 'D': 500, 'M': 1000 };
    let total = 0;
    for (let i = 0; i < s.length; i++) 
    {
        let cur = sym[s[i]], next = sym[s[i + 1]];
        if (cur < next) total -= cur;
        else total += cur;
    }
    return total;
};
